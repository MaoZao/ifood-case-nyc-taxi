# Copie para .env e ajuste conforme o ambiente. Sobrescreve conf/pipeline.yaml.
IFOOD_ENV=local
IFOOD_CONFIG=conf/pipeline.yaml
IFOOD_FORMAT=delta            # delta | parquet

# Caminhos das camadas (local, S3 ou DBFS)
IFOOD_LANDING=data/landing
IFOOD_BRONZE=data/bronze
IFOOD_SILVER=data/silver
IFOOD_GOLD=data/gold

# === Modo CLOUD (MinIO / S3) ==================================================
# Descomente para usar o lakehouse sobre object storage S3-compatível.
# Os caminhos vêm de conf/pipeline.cloud.yaml (bronze/silver/gold em s3a://).
# Definir IFOOD_S3_ENDPOINT é o que ATIVA o conector s3a no Spark (ver spark.py).
# IFOOD_ENV=cloud
# IFOOD_S3_ENDPOINT=http://minio:9000   # use http://localhost:9000 fora do Docker
# AWS_ACCESS_KEY_ID=minio
# AWS_SECRET_ACCESS_KEY=minio123
# IFOOD_S3_PATH_STYLE=true              # obrigatório para MinIO
